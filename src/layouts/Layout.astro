---
/* Cascarón de nicoleolavarria.com.

   El contenido y el diseño ya NO viven aquí: los arma src/lib/web-render.mjs a
   partir de lo que Nicole publica desde su CRM ("Mi web"). Este layout hace tres
   cosas: renderiza ese HTML en el build (SEO), aplica su estilo, y deja un
   script que re-renderiza al vuelo si ella publicó algo después del último
   deploy de Vercel — así ve su cambio al instante, sin esperar un rebuild. */
import { obtenerWeb, ORIGEN } from '../lib/web-data.mjs';
import { htmlPagina, headerHtml, pieHtml, anuncioHtml, estiloCss, fuentesHref, mezclar } from '../lib/web-render.mjs';

interface Props {
  pagina: 'inicio' | 'acerca' | 'sesiones' | 'contacto';
  title: string;
  description?: string;
  image?: string;
}
const {
  pagina,
  title,
  description = 'Clases de canto, técnica vocal y lenguaje musical en Lima. Sesiones 1:1 con Nicole Olavarría, soprano y artista escénica.',
  image,
} = Astro.props;

const { web, version } = await obtenerWeb();
const data = mezclar(web);
const conHeader = pagina !== 'inicio';

const ogImage = image ?? 'https://nicoleolavarria.com/images/sesiones.jpg';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const cssExtra = estiloCss(data);
const hrefFuentes = fuentesHref(data);
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet" />
  {hrefFuentes && <link href={hrefFuentes} rel="stylesheet" id="fuentesNicole" />}
  <link rel="stylesheet" href="/styles/global.css" />
  {cssExtra && <style id="estiloNicole" set:html={cssExtra} />}
</head>
<body data-pagina={pagina} data-webver={version}>
  <Fragment set:html={anuncioHtml(data)} />
  {conHeader && <Fragment set:html={headerHtml(data)} />}

  <main>
    <Fragment set:html={htmlPagina(pagina, data)} />
  </main>

  <Fragment set:html={pieHtml(data)} />

  <script is:inline define:vars={{ ORIGEN }}>
    /* Menú móvil. Se re-engancha después de cada render. */
    window.engancharMenu = function () {
      var toggle = document.querySelector('.menu-toggle');
      var nav = document.querySelector('header nav');
      if (!toggle || !nav || toggle.dataset.on) return;
      toggle.dataset.on = '1';
      toggle.addEventListener('click', function () {
        var open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav.classList.toggle('open', !open);
      });
      nav.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
          nav.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    };
    window.engancharMenu();

    /* Puesta al día: si Nicole publicó después del último build de Vercel, el
       HTML estático está viejo. Se re-renderiza en el navegador con el MISMO
       módulo que usó el build, así lo que ve es exactamente lo que publicó.
       Cualquier falla se traga: la página ya está pintada y no debe romperse. */
    (function () {
      var body = document.body;
      fetch(ORIGEN + '/api/publico')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d || !d.web) return;
          if ((d.web_version || '') === (body.dataset.webver || '')) return; // el build ya está al día
          var s = document.createElement('script');
          s.src = '/js/web-render.js';
          s.onload = function () {
            try { repintar(d.web); } catch (e) {}
          };
          document.head.appendChild(s);
        })
        .catch(function () {});

      function repintar(web) {
        var W = window.WebRender;
        if (!W) return;
        var data = W.mezclar(web);
        var pagina = document.body.dataset.pagina || 'inicio';

        var href = W.fuentesHref(data);
        var lf = document.getElementById('fuentesNicole');
        if (href && !lf) {
          lf = document.createElement('link'); lf.rel = 'stylesheet'; lf.id = 'fuentesNicole';
          document.head.appendChild(lf);
        }
        if (lf && href) lf.href = href;

        var st = document.getElementById('estiloNicole');
        if (!st) { st = document.createElement('style'); st.id = 'estiloNicole'; document.head.appendChild(st); }
        st.textContent = W.estiloCss(data);

        var an = document.querySelector('.anuncio');
        var anHtml = W.anuncioHtml(data);
        if (an) an.remove();
        if (anHtml) document.body.insertAdjacentHTML('afterbegin', anHtml);

        var head = document.querySelector('header');
        if (pagina !== 'inicio') {
          var nuevo = W.headerHtml(data);
          if (head) head.outerHTML = nuevo;
          else document.querySelector('main').insertAdjacentHTML('beforebegin', nuevo);
          window.engancharMenu();
        } else if (head) { head.remove(); }

        document.querySelector('main').innerHTML = W.htmlPagina(pagina, data);
        var pie = document.querySelector('footer');
        if (pie) pie.outerHTML = W.pieHtml(data);
      }
    })();
  </script>
</body>
</html>
