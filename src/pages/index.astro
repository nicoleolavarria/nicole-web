---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nicole Olavarría — canto, técnica vocal y lenguaje musical">
  <div class="home-hero">
    <h1>Nicole Olavarría</h1>
    <p class="sub">soprano · artista escénica · compositora</p>

    <div class="home-social">
      <a href="https://www.instagram.com/nicoleolavarria_______/" target="_blank" rel="noopener">instagram</a>
      <a href="/sesiones">sesiones</a>
      <a href="/contacto">contacto</a>
    </div>

    <img
      src="/images/sesiones.jpg"
      alt="Nicole Olavarría en sesión de canto"
      class="hero-img"
    />

    <a href="/sesiones" class="home-cta">sesiones 1:1 →</a>
  </div>

  <section class="wrap" style="padding-top: 0; padding-bottom: 100px;">
    <div style="max-width: 560px;">
      <h2>sobre</h2>
      <p>
        Cantante, artista escénica y compositora. Enseña técnica vocal y
        lenguaje musical desde 2020. Sesiones individuales en San Isidro,
        Miraflores y online.
      </p>
      <p class="muted small">
        gracias por visitar nicoleolavarria.com
      </p>
    </div>
  </section>
</Layout>
