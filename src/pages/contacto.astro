---
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/51955127656?text=hola%2C%20por%20favor%20podr%C3%ADas%20enviarme%20m%C3%A1s%20informaci%C3%B3n%20sobre%20las%20sesiones%201%3A1%3F';
---
<Layout
  title="Contacto — Nicole Olavarría"
  description="Contacta a Nicole Olavarría para información sobre sesiones de canto y técnica vocal en Lima."
>
  <div class="wrap-narrow">
    <h1>Contacto</h1>

    <div style="margin-top: 48px;">
      <div class="contact-item">
        <div class="contact-label">whatsapp</div>
        <div class="contact-value">
          <a href={WA} target="_blank" rel="noopener">+51 955 127 656</a>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-label">correo</div>
        <div class="contact-value">
          <a href="mailto:holanicoleolavarria@gmail.com">holanicoleolavarria@gmail.com</a>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-label">ubicación</div>
        <div class="contact-value muted">San Isidro · Miraflores · online</div>
      </div>

      <div class="contact-item">
        <div class="contact-label">instagram</div>
        <div class="contact-value">
          <a href="https://www.instagram.com/nicoleolavarria_______/" target="_blank" rel="noopener">@nicoleolavarria_______</a>
        </div>
      </div>
    </div>
  </div>
</Layout>
