---
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/51955127656?text=hola%2C%20por%20favor%20podr%C3%ADas%20enviarme%20m%C3%A1s%20informaci%C3%B3n%20sobre%20las%20sesiones%201%3A1%3F';
---
<Layout
  title="Sesiones 1:1 — Nicole Olavarría"
  description="Sesiones individuales de canto, técnica vocal y lenguaje musical en Lima. Tres modalidades: Descubrir mi voz, Cantores y Lenguaje musical."
  image="/images/sesiones.jpg"
>
  <div class="wrap">
    <div class="sesiones-hero">
      <div>
        <h1>Sesiones 1:1</h1>
        <p>
          Clases individuales de técnica vocal y lenguaje musical. Duración de
          cada sesión: <strong>1 hora</strong>.
        </p>
        <p class="muted small">Foto: Carlos Cabrera</p>
        <a href={WA} class="btn-agenda" target="_blank" rel="noopener">agenda aquí</a>
      </div>
      <div>
        <img src="/images/sesiones.jpg" alt="Sesión de canto con Nicole Olavarría" style="width:100%; object-fit:cover;" />
      </div>
    </div>

    <h2>modalidades</h2>

    <div class="sesion-card">
      <h3>Descubrir mi voz</h3>
      <p>Pensadas para principiantes o personas sin experiencia en técnica vocal.</p>
    </div>

    <div class="sesion-card">
      <h3>Cantores</h3>
      <p>Pensadas para personas con mediana experiencia en técnica vocal.</p>
    </div>

    <div class="sesion-card">
      <h3>Lenguaje musical</h3>
      <p>Pensadas para aprender teoría musical, entrenamiento auditivo y lectura de partituras.</p>
    </div>

    <div class="sesiones-meta">
      <span>San Isidro · Miraflores · online</span>
      <span>cupos limitados</span>
    </div>

    <a href={WA} class="btn-agenda" target="_blank" rel="noopener">agenda aquí</a>
  </div>
</Layout>
